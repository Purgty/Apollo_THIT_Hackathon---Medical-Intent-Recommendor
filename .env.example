# ─────────────────────────────────────────────────────────────────────────────
# Apollo Clinical Intelligence — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# DO NOT commit .env to git.
#
# Usage (local dev):  cp .env.example .env
# Usage (Docker):     docker compose --env-file .env up
# ─────────────────────────────────────────────────────────────────────────────

# ── LM Studio ──────────────────────────────────────────────────────────────
# URL of the LM Studio local server.
# For Docker on Windows/Mac: use host.docker.internal
# For Docker on Linux:       use host.docker.internal (via extra_hosts)
# For local dev:             use 127.0.0.1
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=local-model

# ── Data Paths ─────────────────────────────────────────────────────────────
# Absolute path to the raw Apollo product catalog CSV.
# Default (local dev): auto-resolved relative to project root.
# CATALOG_RAW_PATH=/data/Main_Apollo_Catalog.csv

# Directory where FAISS index and metadata will be saved.
# ARTIFACTS_DIR=/app/final_implementation/artifacts

# ── Embedding Model ─────────────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64

# ── FAISS ───────────────────────────────────────────────────────────────────
FAISS_INDEX_TYPE=flat
FAISS_TOP_K_CANDIDATES=50
FINAL_TOP_K=10
MAX_VECTOR_DISTANCE=2.0

# ── LLM Behaviour ───────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# ── API Server ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_WORKERS=1
